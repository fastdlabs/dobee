{
    "name": "fastd/dobee",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "keywords": [
        "FastD"
    ],
    "authors": [
        {
            "name": "JanHuang",
            "email": "bboyjanhuang@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "": "src"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../container"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../event"
        },
        {
            "type": "path",
            "url": "../middleware"
        },
        {
            "type": "path",
            "url": "../http"
        },
        {
            "type": "path",
            "url": "../routing"
        },
        {
            "type": "path",
            "url": "../swoole"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../medoodb"
        },
        {
            "type": "path",
            "url": "../fastD"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-pdo": "*",
        "fastd/cache": "dev-master",
        "fastd/container": "dev-master",
        "fastd/config": "dev-master",
        "fastd/middleware": "dev-master",
        "fastd/http": "dev-master",
        "fastd/routing": "dev-master",
        "fastd/medoodb": "dev-master",
        "fastd/swoole": "dev-master",
        "fastd/fastd": "dev-master",

        "monolog/monolog": "^3.0",
        "symfony/console": "^8.1",
        "symfony/yaml": "^8.1",
        "symfony/cache": "*",
        "catfan/medoo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "swoole/ide-helper": "@dev"
    },
    "config": {
        "bin-dir": "bin"
    }
}
